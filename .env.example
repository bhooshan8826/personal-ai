# App Configuration
APP_NAME=Personal AI Assistant
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=sqlite:///./data/app.db
# For PostgreSQL: postgresql://user:password@localhost:5432/personal_ai

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ENCRYPTION_KEY=your-encryption-key-here-32-chars-min

# LLM Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
EMBEDDING_MODEL=nomic-embed-text

# API
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Optional: Claude API for fallback
CLAUDE_API_KEY=your-claude-api-key-here

# Vector Database
CHROMA_HOST=localhost
CHROMA_PORT=8000
VECTOR_DB_PATH=data/vector_db

# Email (for Phase 2)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Calendar (for Phase 2)
CALENDAR_SERVICE=google  # google, outlook, etc.
CALENDAR_API_KEY=your-calendar-api-key
